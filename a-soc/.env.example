# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
OPENAI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here
DEEPSEEK_API_KEY=your_key_here

# Local LLM (used when LLM_PROVIDER=ollama or LLM_PROVIDER=local)
LOCAL_LLM_MODEL=llama3
LOCAL_LLM_BASE_URL=http://ollama:11434

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project
GCP_CREDENTIALS_PATH=/path/to/service-account.json

# Azure Configuration
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_SUBSCRIPTION_ID=your-subscription-id

# Database Configuration
DATABASE_URL=postgresql+asyncpg://asoc_user:changeme123@postgres:5432/asoc_db
REDIS_URL=redis://:changeme123@redis:6379/0
REDIS_PASSWORD=changeme123
POSTGRES_PASSWORD=changeme123

# Security Configuration
OPA_URL=http://opa:8181
VAULT_ADDR=http://localhost:8200
HMAC_SECRET=change-this-to-a-random-secret-in-production
WS_API_TOKEN=dev-token

# JWT RS256 (leave blank for dev — ephemeral keypair auto-generated)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Per-Agent Rate Limits (requests/minute)
RATE_LIMIT_AGENT_TELEMETRY=200
RATE_LIMIT_AGENT_DETECTION=30
RATE_LIMIT_AGENT_FORENSICS=20
RATE_LIMIT_AGENT_RESPONSE=15
RATE_LIMIT_AGENT_SUPERVISOR=25
RATE_LIMIT_AGENT_NOTIFICATION=50
RATE_LIMIT_AGENT_COMPLIANCE=40

# Rate Limiting
RATE_LIMIT_CAPACITY=120
RATE_LIMIT_REFILL_RATE=2

# Vector DB (Pinecone)
PINECONE_API_KEY=your_key
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=asoc-incidents

# Notification Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
TEAMS_WEBHOOK_URL=https://your-domain.webhook.office.com/webhookb2/your-webhook

# JIRA Integration
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=SEC

# Worker Configuration
WORKER_POLL_INTERVAL=5

# Observability — LangSmith Tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key
LANGCHAIN_PROJECT=a-soc

# Observability — OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Monitoring — Grafana
GRAFANA_PASSWORD=admin

# CORS
CORS_ORIGINS=http://localhost:3000
