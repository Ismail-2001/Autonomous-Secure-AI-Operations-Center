# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
OPENAI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here
DEEPSEEK_API_KEY=your_key_here

# Local LLM (used when LLM_PROVIDER=ollama or LLM_PROVIDER=local)
LOCAL_LLM_MODEL=llama3
LOCAL_LLM_BASE_URL=http://localhost:11434

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project
GCP_CREDENTIALS_PATH=/path/to/service-account.json

# Azure Configuration
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_SUBSCRIPTION_ID=your-subscription-id

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/asoc
REDIS_URL=redis://localhost:6379/0

# Security Configuration
OPA_URL=http://localhost:8181
VAULT_ADDR=http://localhost:8200
HMAC_SECRET=change-this-to-a-random-secret-in-production
WS_API_TOKEN=dev-token

# Vector DB (Pinecone)
PINECONE_API_KEY=your_key
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=asoc-incidents

# Notification Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
TEAMS_WEBHOOK_URL=https://your-domain.webhook.office.com/webhookb2/your-webhook

# JIRA Integration
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=SEC
